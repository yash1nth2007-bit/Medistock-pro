# ============================================================
# MediStock Pro Enterprise AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- App ----
NODE_ENV=development
APP_NAME="MediStock Pro Enterprise AI"
APP_URL=http://localhost:5000

# ---- Frontend ----
VITE_API_URL=http://localhost:5000/api
VITE_AI_URL=http://localhost:8000
VITE_APP_NAME="MediStock Pro Enterprise AI"
VITE_ADMIN_ROUTE=/super-admin

# ---- Backend Port ----
PORT=5000

# ---- PostgreSQL Database ----
DATABASE_URL=postgresql://neondb_owner:npg_OD0q4QJhTyYc@ep-polished-mud-aofps4vq-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ---- JWT ----
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="MediStock Pro <noreply@medistock.com>"

# ---- Admin Route (hidden portal) ----
ADMIN_ROUTE=/super-admin
SUPER_ADMIN_EMAIL=superadmin@medistock.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# ---- AI Service ----
AI_SERVICE_URL=http://localhost:8000
FLASK_SECRET_KEY=flask_secret_key_change_in_production

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

FRONTEND_URL=http://localhost:3000
